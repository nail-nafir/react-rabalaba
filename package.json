{
  "name": "react-rabalaba",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "wrangler": "wrangler pages dev --port 8788 -- vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --test tests/*.test.mjs",
    "gate:compare": "node scripts/gate-compare.mjs",
    "build:edge": "esbuild src/core/edge-engine.ts --bundle --format=esm --platform=neutral --alias:@=./src --outfile=supabase/functions/auto-journal/_engine.mjs && esbuild src/core/edge-engine.ts --bundle --format=esm --platform=neutral --alias:@=./src --outfile=supabase/functions/daily-summary/_engine.mjs",
    "deploy:edge": "npm run build:edge && npx supabase functions deploy auto-journal --project-ref nravncsodgcxwkdaeqcw",
    "deploy:summary": "npm run build:edge && npx supabase functions deploy daily-summary --project-ref nravncsodgcxwkdaeqcw",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
